{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Transaction",
  "type": "object",
  "properties": {
    "schemaVersion": {
      "type": "string",
      "enum": ["1.0.0"]
    },
    "traceId": {
      "type": "string",
      "format": "uuid"
    },
    "transactionId": {
      "type": "string"
    },
    "idempotencyKey": {
      "type": "string",
      "format": "uuid"
    },
    "customerId": {
      "type": "string"
    },
    "cardId": {
      "type": "string"
    },
    "amount": {
      "type": "number"
    },
    "currency": {
      "type": "string",
      "enum": ["USD", "EUR", "GBP", "JPY", "CAD"]
    },
    "merchant": {
      "type": "string"
    },
    "merchantCategory": {
      "type": "string"
    },
    "location": {
      "type": "string"
    },
    "latitude": {
      "type": "number"
    },
    "longitude": {
      "type": "number"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    }
  },
  "required": [
    "schemaVersion",
    "traceId",
    "transactionId",
    "idempotencyKey",
    "customerId",
    "cardId",
    "amount",
    "currency",
    "merchant",
    "merchantCategory",
    "location",
    "latitude",
    "longitude",
    "timestamp"
  ]
}